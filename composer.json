{
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0",
    "friendsofphp/php-cs-fixer": "^3.17",
    "phpunit/phpunit": "^9.5"
  },
  "config": {
    "platform": {
      "php": "7.4"
    }
  },
  "scripts": {
    "phpcs": "phpcs --standard=PSR12 controllers/ models/ config/",
    "phpcbf": "phpcbf --standard=PSR12 controllers/ models/ config/",
    "phpcs:all": "phpcs --standard=PSR12 .",
    "test": "phpunit"
  }
}
